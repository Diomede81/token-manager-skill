{
  "name": "token-manager-skill",
  "version": "1.0.0",
  "description": "OpenClaw skill for centralized API token registry and management",
  "main": "scripts/server.js",
  "scripts": {
    "start": "node scripts/server.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop token-manager",
    "restart:pm2": "pm2 restart token-manager",
    "status:pm2": "pm2 status token-manager",
    "logs:pm2": "pm2 logs token-manager",
    "verify": "node scripts/verify-tokens.js",
